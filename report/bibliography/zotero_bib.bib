  file = {C:\Users\AAg\OneDrive - Allseas Engineering BV\Documents\Thesis\Thesis-Literature - Documents\Nghiem et al. - 2023 - Physics-Informed Machine Learning for Modeling and Control of Dynamical Systems.pdf}
