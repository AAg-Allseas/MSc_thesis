  pages = {103191},
  issn = {0010-4485},
  doi = {10.1016/j.cad.2021.103191},
  url = {https://www.sciencedirect.com/science/article/pii/S001044852100186X},
  urldate = {2025-11-25},
  abstract = {We propose the use of existing data standards and web technologies to modeling and development of digital twin ships. Our research provides an open framework that can be linked to services such as visualizations, simulations and remote control. The case study applies the standards-based framework to an experiment that involved a scale model ship equipped with a dynamic positioning system under artificial waves. The digital twin prototype illustrated the capability of mirroring and controlling the model’s position in real-time, and predicting motion responses across wave conditions via a web application. Thus, it closes the loop between test and design in the life cycle by allowing validation of results in comparison to empirical data during operation. The results from these experiments are used to discuss an expanded version of the digital twin for validation and optimization of motion response, as well as its implications to the system’s (ship) taxonomy and data management. The conclusion summarizes lessons when using the adopted standards, as well as challenges when scaling the approach to real life operations. Future research is proposed toward extending the standardization to more complex cases.},
  keywords = {Data standard,Digital twin,Internet of things,Remote operations,Ship,Simulation},
  file = {C\:\\Users\\AAg\\OneDrive - Allseas Engineering BV\\Documents\\Thesis\\Thesis-Literature - Documents\\Fonseca et al. - 2022 - A Standards-Based Digital Twin of an Experiment with a Scale Model Ship.pdf;C\:\\Users\\AAg\\Zotero\\storage\\IL68NKRY\\S001044852100186X.html}
}

