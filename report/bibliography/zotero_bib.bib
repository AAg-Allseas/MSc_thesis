@online{nghiemPhysicsInformedMachineLearning2023,
  title = {Physics-{{Informed Machine Learning}} for {{Modeling}} and {{Control}} of {{Dynamical Systems}}},
  author = {Nghiem, Truong X. and Drgoňa, Ján and Jones, Colin and Nagy, Zoltan and Schwan, Roland and Dey, Biswadip and Chakrabarty, Ankush and Cairano, Stefano Di and Paulson, Joel A. and Carron, Andrea and Zeilinger, Melanie N. and Cortez, Wenceslao Shaw and Vrabie, Draguna L.},
