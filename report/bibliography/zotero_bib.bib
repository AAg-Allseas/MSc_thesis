@article{gongPhysicsinformedGloballocalNeural2025,
  title = {A Physics-Informed Global-Local Neural Operator for Parametric Stochastic Differential Equations},
  author = {Gong, Yi and Cheung, Sai Hung},
  date = {2025-11-08},
  journaltitle = {Engineering Applications of Artificial Intelligence},
