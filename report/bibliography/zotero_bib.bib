@article{bettiniDatadrivenNonlinearModel2025,
  title = {Data-Driven Nonlinear Model Reduction to Spectral Submanifolds via Oblique Projection},
  author = {Bettini, Leonardo and Kaszás, Bálint and Zybach, Bernhard and Dual, Jürg and Haller, George},
  date = {2025-04-18},
  journaltitle = {Chaos: An Interdisciplinary Journal of Nonlinear Science},
