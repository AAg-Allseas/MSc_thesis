@article{wangIntelligentAdaptiveControl2025,
  title = {Intelligent Adaptive Control of Ship Dynamic Positioning Using Extreme Learning Machine and Disturbance Observer},
  author = {Wang, Hongdu and Zhao, Wenwen and Karkoub, Mansour and Wang, Junrong},
  date = {2025},
  journaltitle = {Engineering Applications of Artificial Intelligence},
  shortjournal = {Eng Appl Artif Intell},
  volume = {155},
  publisher = {Elsevier Ltd},
  issn = {0952-1976},
  doi = {10.1016/j.engappai.2025.111061},
  abstract = {Ships are often affected by many different types of disturbances during their voyage. In this paper, a prescribed performance control scheme based on adaptive extreme learning machine (ELM) and disturbance observer is proposed to solve the control problem of ship dynamic positioning (DP) with multiple disturbances. These include unknown nonlinearities in the ship model and wave disturbances modeled using nonlinear exosystems. The unknown nonlinear function is included in the exosystem, which makes the wave model more realistic. ELM is a machine learning method based on feedforward neural network, which is faster than the traditional single-hidden layer feedforward neural network and ensures high learning accuracy. First, the ELM network is applied to approximate the unknown nonlinear functions in the DP and exosystems. Subsequently, a neural network disturbance observer based on ELM is designed to estimate the external disturbances. With an accurate estimate, one can design a controller to compensate for the disturbances. In order to improve the closed-loop control precision and dynamic performance, performance functions are designed to constrain the error vector of the system. This design can ensure the convergence of the state error of the ship system in a predetermined time. Using the ELM disturbance observer technique, prescribed performance functions, and the command filter backstepping method, a neural network-based anti-disturbance control scheme with prescribed performance for ship DP system is developed here. The closed-loop stability of the combined DP ship system with unknown model nonlinearities and disturbances modeled using a nonlinear exosystem is analyzed via Lyapunov function. Virtual experiments showed that the DP ship controlled by the proposed method can quickly track the reference trajectory and maintain stability when unknown nonlinearities of the model and external wave disturbances are included. The proposed method improves the anti-disturbance ability of DP ships and helps maintain smooth sailing missions and exploration activities. © 2025 Elsevier Ltd},
  langid = {english},
  keywords = {Anti-disturbance control,Extreme learning machine disturbance observer,Nonlinear exosystem,Prescribed performance control},
  file = {C\:\\Users\\AAg\\OneDrive - Allseas Engineering BV\\Documents\\Thesis\\Thesis-Literature - Documents\\Wang et al. - 2025 - Intelligent adaptive control of ship dynamic positioning using extreme learning machine and disturba.pdf;C\:\\Users\\AAg\\Zotero\\storage\\R8J9KEEV\\105005106070.html}
}

