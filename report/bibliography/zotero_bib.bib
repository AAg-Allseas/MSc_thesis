@article{wangFlowbasedBayesianFiltering2025,
  title = {Flow-Based {{Bayesian}} Filtering for High-Dimensional Nonlinear Stochastic Dynamical Systems},
  author = {Wang, Xintong and Guan, Xiaofei and Guo, Ling and Wu, Hao},
  date = {2025-11-01},
  journaltitle = {Computer Methods in Applied Mechanics and Engineering},
