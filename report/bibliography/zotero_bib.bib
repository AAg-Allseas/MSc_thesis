@article{nathanielDeepKoopmanOperators2025,
  title = {Deep {{Koopman}} Operators for Causal Discovery},
  author = {Nathaniel, Juan and Roesch, Carla and Buch, Jatan and DeSantis, Derek and Rupe, Adam and Lamb, Kara D. and Gentine, Pierre},
  date = {2025-11-20},
  journaltitle = {Communications Physics},
