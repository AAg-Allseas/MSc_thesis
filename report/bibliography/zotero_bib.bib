  urldate = {2025-12-05},
  abstract = {The effective management of modern smart grids requires accurate short-term and long-term load forecasting while identifying scalable, interpretable consumption patterns to enable demand response (DR) and enhance renewable integration. This paper presents a comprehensive, scalable pipeline for high-frequency household energy data analysis, integrating weather information to improve forecasting accuracy. The methodology combines Uniform Manifold Approximation and Projection (UMAP) for dimensionality reduction, ensemble clustering methods (HDBSCAN and Gaussian Mixture Models) for advanced segmentation, and hybrid forecasting models (LSTM with attention mechanisms and XGBoost with quantile regression) for probabilistic forecasting. Evaluations across multiple horizons (1-hour, 4-hour, 24-hour) using deterministic metrics (MAE, RMSE) and probabilistic metrics (CRPS, Pinball Loss) show that cluster-wise probabilistic forecasting achieves up to 15\% reduction in CRPS and 12\% reduction in MAE compared to global models. Additional sensitivity and ablation studies confirm that weather integration improves MAE by approximately 9\%, while attention mechanisms enhance LSTM performance by 6\%–8\%. These results demonstrate that the proposed approach provides actionable insights for targeted DR, peak load reduction, and renewable integration within smart grids.},
  langid = {english},
  file = {C:\Users\AAg\OneDrive - Allseas Engineering BV\Documents\Thesis\Thesis-Literature - Documents\Tsiakalos and Tsiakalos - 2026 - Scalable probabilistic load forecasting and advanced clustering for smart grids using high-frequency.pdf}
