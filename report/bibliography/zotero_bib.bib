@article{fruzzettiProbabilisticOperabilityGreenhouse2024,
  title = {Probabilistic Operability and Greenhouse Gas Assessment during Dynamic Positioning Operations},
  author = {Fruzzetti, Camilla and Donnarumma, Silvia and Maggiani, Francesca and Martelli, Michele},
  date = {2024-05-01},
  journaltitle = {Proceedings of the Institution of Mechanical Engineers, Part M: Journal of Engineering for the Maritime Environment},
  shortjournal = {Proceedings of the Institution of Mechanical Engineers, Part M: Journal of Engineering for the Maritime Environment},
  volume = {238},
  number = {2},
  pages = {336--347},
  publisher = {SAGE Publications},
