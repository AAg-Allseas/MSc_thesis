  url = {https://www.sciencedirect.com/science/article/pii/S0952197625015258},
  urldate = {2026-02-16},
  abstract = {Deep operator network (DeepONet) learning the mapping between infinite-dimensional functions has provided a promising paradigm for learning parametric stochastic differential equations (PSDE). As an extension of DeepONet, Multi-input operator network (MIONet) allows handling multiple input functions effectively. In this study, inspired by MIONet, a physics-informed global-local neural operator (PIGLNO) is established for learning PSDE considering the uncertainties induced by multiple stochastic processes and uncertain parameters. Compared with the vanilla MIONet, our proposed PIGLNO considers both global functions evaluated at fixed grids and local functions evaluated at any discretized location simultaneously, enabling the proposed approach's efficient adaptability to varying-resolution inputs without re-training. Besides, our proposed PIGLNO does not require any conventional solver and is purely physics-informed at training time. Numerical studies demonstrate that our PIGLNO outperforms the physics-informed MIONet and achieves a strong gain in accuracy and efficiency for uncertainty quantification of PSDEs solutions. Our PIGLNO also provides useful information for rare event estimation of stochastic physical systems.},
  keywords = {Multiple stochastic processes,Parametric stochastic differential equation,Physics-informed global-local neural operator,Uncertainty quantification},
  file = {C\:\\Users\\AAg\\OneDrive - Allseas Engineering BV\\Documents\\Thesis\\Thesis-Literature - Documents\\Gong and Cheung - 2025 - A physics-informed global-local neural operator for parametric stochastic differential equations.pdf;C\:\\Users\\AAg\\Zotero\\storage\\2VBYLT7F\\S0952197625015258.html}
}

@article{goswamiNeuralOperatorsStochastic2025,
  title = {Neural Operators for Stochastic Modeling of Nonlinear Structural System Response to Natural Hazards},
  author = {Goswami, Somdatta and Giovanis, Dimitris G. and Li, Bowei and Spence, Seymour M. J. and Shields, Michael D.},
  date = {2025-12-15},
  journaltitle = {Engineering Structures},
  shortjournal = {Engineering Structures},
  volume = {345},
  pages = {121284},
  issn = {0141-0296},
  doi = {10.1016/j.engstruct.2025.121284},
  url = {https://www.sciencedirect.com/science/article/pii/S014102962501675X},
  urldate = {2026-02-16},
  abstract = {Traditionally, neural networks have been employed to learn the mapping between finite-dimensional Euclidean spaces. However, recent research has opened up new horizons, focusing on the utilization of deep neural networks to learn operators capable of mapping infinite-dimensional function spaces. In this work, we employ two state-of-the-art neural operators, the deep operator network (DeepONet) and the Fourier neural operator (FNO) for the prediction of the nonlinear time history response of structural systems exposed to natural hazards, such as earthquakes and windstorms. Specifically, we propose two architectures, a self-adaptive FNO and a fast Fourier transform-based DeepONet (DeepFNOnet), where we employ a FNO beyond the DeepONet to learn the discrepancy between the ground truth and the solution predicted by the DeepONet. To demonstrate the efficiency and applicability of the architectures, two problems are considered. In the first, we use the proposed model to predict the seismic nonlinear dynamic response of a six-story shear building subject to stochastic ground motions. In the second problem, we employ the operators to predict the wind-induced nonlinear dynamic response of a high-rise building while explicitly accounting for the stochastic nature of the wind excitation. In both cases, the trained metamodels achieve high accuracy while being orders of magnitude faster than their corresponding high-fidelity models.},
  keywords = {DeepONet,FNO,Natural hazards,Nonlinear dynamic response metamodeling,ODE emulator},
  file = {C\:\\Users\\AAg\\OneDrive - Allseas Engineering BV\\Documents\\Thesis\\Thesis-Literature - Documents\\Goswami et al. - 2025 - Neural operators for stochastic modeling of nonlinear structural system response to natural hazards.pdf;C\:\\Users\\AAg\\Zotero\\storage\\8XG6XEJG\\S014102962501675X.html}
}

