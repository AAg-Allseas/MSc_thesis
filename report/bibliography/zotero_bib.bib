@inproceedings{pivanoDigitalTwinDrilling2019,
  title = {Digital {{Twin}} for {{Drilling Operations}} – {{Towards Cloud-Based Operational Planning}}},
  author = {Pivano, Luca and Nguyen, Dong Trong and Bruun Ludvigsen, Kristine},
  date = {2019-04-26},
