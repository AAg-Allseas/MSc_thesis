@thesis{dewetFrequencyDomainApproach2019,
  title = {A {{Frequency Domain Approach}} to {{Estimate DP Footprint}}},
  author = {De Wet, Pieter},
  date = {2019},
  url = {https://repository.tudelft.nl/record/uuid:6a4d4227-357a-43ad-ac5c-67140678bd49},
  urldate = {2025-12-03},
  abstract = {Offshore operations are increasingly executed by vessels operating on dynamic positioning (DP) due to advantages it has for short operations, such as maintenance and crew transfer but also for track keeping operations and projects in deeper water. Currently, DP capability plots are used to indicate whether an operation can be performed, but this is based on static calculations and it does not consider the offsets that are found due to motions of the vessel, while the offsets can be critical in case a structure is present or if a certain accuracy of a station keeping operation is necessary. Currently, to determine the offsets of a vessel on DP, the system is modelled using a time domain approach. Multiple simulation runs are carried out to calculate the expected extreme offsets in a given time interval, which is known as the most probable maximum offset (MPM offset). This is a complex and time consuming process and therefore it is not always done in practice before an operation starts. In this research, a method is developed to estimate the surge MPM offsets of a vessel on DP due to the wave drift forces using a frequency domain approach, as this can lead to faster estimates. But two problems are faced: The first is that there is no mathematical model available describing a vessel on DP which can be used to accurately calculate the offsets in the frequency domain. The second problem is that there is no known relation between the offsets and the extreme behaviour, which leads to the MPM offsets. To find the MPM offsets, first of all a one-dimensional time domain model of a vessel on DP is made, considering only the surge degree of freedom. Next, to determine the surge offset response using a frequency domain approach, the differential equations of the system are linearised, which gives the transfer functions from the environmental forces to the surge offsets. This is used to estimate the surge offset response in the frequency domain. The accuracy of this method is determined by comparing the root mean square value (RMS) and the zero up crossing period to that of the time domain results. Then, two alternative methods are developed to calculate the MPM offsets from the surge offset response characteristics directly. The methods use the RMS and zero up crossing period of the surge offsets calculated in the frequency domain, to determine the extreme behaviour statistically without the use of multiple simulation runs. Using the linearised model of the vessel on DP, it is found that the surge offset response can be calculated within an accuracy of 4\% of the results generated by the time domain simulations, based on the root mean square value and the zero crossing period. Therefore, an accurate estimate of the surge offsets is found using a frequency domain approach. Both alternative MPM offset calculation methods, using the surge offset results of the linearised model, give MPM offset estimates within approximately 10\% of the results of the time domain simulation approach. Taking into account the strong variability found in the MPM offsets calculated by the time domain approach, the estimates from the frequency domain approach are regarded as good estimates. {$<$}br/{$>$}It is concluded that the methods developed in this research can lead to faster and therefore timely MPM offset estimates to use for the safety and accuracy of operations. This can improve the way of working for many offshore operations where often no use is made of MPM offset estimates due to the disadvantages of the methods currently used in practice. It is recommended to extend the method developed in this research to three degrees of freedom, such that it can be implemented in practice.},
  langid = {english},
  file = {C:\Users\AAg\OneDrive - Allseas Engineering BV\Documents\Thesis\Thesis-Literature - Documents\De Wet - 2019 - A Frequency Domain Approach to Estimate DP Footprint.pdf}
}

@article{dingHydrodynamicsIdentificationDynamic2025,
  title = {Hydrodynamics Identification of a Dynamic Positioning Vessel with Uncertainties: {{A}} Rapid Online Physics-Informed Approach},
  shorttitle = {Hydrodynamics Identification of a Dynamic Positioning Vessel with Uncertainties},
  author = {Ding, Ming and Wang, Lei and Wang, Yiting and Hu, Juxi and Yang, Peng},
  date = {2025-12},
  journaltitle = {Ocean Engineering},
  shortjournal = {Ocean Engineering},
  volume = {342},
  pages = {122972},
  issn = {00298018},
  doi = {10.1016/j.oceaneng.2025.122972},
  url = {https://linkinghub.elsevier.com/retrieve/pii/S0029801825026551},
  urldate = {2025-11-27},
  abstract = {To address the challenges of strong time-varying hydrodynamic parameters in dynamic positioning (DP) vessels caused by environment variations, load fluctuations, and hull biofouling during practical operations, as well as the limitations of traditional identification methods in real-time updates and handling uncertainties under severe disturbances, this study applies the Physics-Informed Neural Networks (PINN) to the hydrodynamic parameters identification. A rapid online physics-informed method, termed VMC-PINN (Variational Monte Carlo PINN), is proposed to identify the hydrodynamics. By learning the probabilistic representation of network weights through variable distributions and employing Dropout-based Monte Carlo approximations for inferences, the dual-stage robustness of PINN against noisy data and model uncertainties is improved. An uncertainty quantification algorithm and an online parameter update mechanism are designed to achieve fast, online hydrodynamic parameter identification with quantifiable uncertainties in high-disturbance environments. Model experiments demonstrate that the proposed method significantly reduces parameter identification errors under environmental disturbances compared to Recursive Least Squares (RLS) and Unscented Kalman Filter (UKF), while maintaining 95 \% confidence interval coverage even during abrupt parameter changes. The online identification framework proposed in this study provides a reference for adaptive parameter updates in DP control systems, substantially improving control accuracy and safety margins.},
  langid = {english},
  file = {C\:\\Users\\AAg\\OneDrive - Allseas Engineering BV\\Documents\\Thesis\\Thesis-Literature - Documents\\Ding et al. - 2025 - Hydrodynamics identification of a dynamic positioning vessel with uncertainties A rapid online phys.pdf;C\:\\Users\\AAg\\Zotero\\storage\\XAXEH6KJ\\S0029801825026551.html}
}

@article{donatiniRealtimeSynthesisDynamic2025,
  title = {Real-Time Synthesis of the Dynamic Responses of Floating Bodies to Waves for Maritime Simulators},
  author = {Donatini, Luca and Verwilligen, Jeroen and Delefortrie, Guillaume and Vantorre, Marc and Lataire, Evert},
  date = {2025-01-01},
  journaltitle = {Applied Ocean Research},
  shortjournal = {Applied Ocean Research},
  volume = {154},
