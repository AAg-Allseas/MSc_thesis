  keywords = {model reduction,spectral theory of dynamical systems},
  file = {C:\Users\AAg\OneDrive - Allseas Engineering BV\Documents\Thesis\Thesis-Literature - Documents\Mezić - 2005 - Spectral Properties of Dynamical Systems, Model Reduction and Decompositions.pdf}
